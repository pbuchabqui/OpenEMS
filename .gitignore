# OpenEMS root .gitignore
# Keep this file free of markdown fences or other non-pattern lines.

# --- Build artifacts ---
*.o
*.obj
*.a
*.so
*.dll
*.exe
*.out
/tmp/
# Host/firmware objects live under /tmp/openems-build by default (Makefile)

# --- Dependencies / Python ---
venv/
.venv/
__pycache__/
*.pyc
*.egg-info/
dist/
build/
target/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*.tmp
*~

# --- Logs ---
*.log
tools/openems_dash/logs/

# --- Environment / secrets ---
.env
.env.local
*.env.*
**/wifi_credentials.h

# --- Coverage ---
coverage/
htmlcov/
.coverage

# --- OS ---
.DS_Store
Thumbs.db

# --- Archives ---
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# --- Knowledge graph (generated; rebuild with graphify) ---
graphify-out/

# --- Ardu-Stim GUI vendor weight (bins, fonts; keep app sources if re-added) ---
tools/esp32_combined/ardustim_gui/bin/
tools/esp32_combined/ardustim_gui/assets/fontawesome/
tools/esp32_combined/ardustim_gui/node_modules/
tools/esp32_combined/ardustim_gui/package-lock.json

# --- Claude / cave local worktrees (if present) ---
.cave/
